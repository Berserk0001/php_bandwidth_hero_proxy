{
    "version": 2,
    "builds": [
        {
            "src": "index.php",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.php"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.php"
        }
    ],
    "functions": {
        "api/**/*.php": {
            "runtime": "php@8.3.11"
        }
    }
}
