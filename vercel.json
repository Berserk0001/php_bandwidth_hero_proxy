{
    "version": 2,
    "name": "vercel-bhero-test",
    "builds": [
        {
            "src": "index.php",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}
